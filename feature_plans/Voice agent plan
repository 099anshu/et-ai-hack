        """Send SMS alert via Authkey.io API.
        
        GET https://api.authkey.io/request?authkey=KEY&mobile=PHONE&country_code=91
            &sms=MESSAGE&sender=RAKSHA
        """
    
    async def send_voice_alert(self, phone: str, message: str) -> dict:
        """Place outbound TTS voice call via Authkey.io.
        
        GET https://api.authkey.io/request?authkey=KEY&mobile=PHONE&country_code=91
