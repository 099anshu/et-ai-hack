# ── WHATSAPP (KAVACH-WA) ────────────────────────────────────────────────────
class WhatsAppStatus(BaseModel):
    connected: bool = False
    qr_ready: bool = False
    phone: Optional[str] = None

class WhatsAppChat(BaseModel):
    id: str
    name: str
    isGroup: bool = False
    timestamp: Optional[int] = None
    unreadCount: int = 0
    lastMessage: Optional[str] = None

class WhatsAppMessage(BaseModel):
    id: str
    from_: str = Field(alias="from")
    body: str
    timestamp: int
    fromMe: bool = False
    type: str = "chat"

class FlaggedMessage(BaseModel):
    message_index: int
    message_body: str
    risk_level: str            # critical | high | medium | low
    threat_type: str           # SCAM | PHISHING | FINANCIAL_FRAUD | etc.
    explanation: str
    recommendation: str

class ChatAnalysisResult(BaseModel):
    chat_id: str
    chat_name: str
    overall_risk: str          # safe | low | medium | high | critical
    summary: str
    flagged_messages: list[FlaggedMessage] = Field(default_factory=list)
    key_findings: list[str] = Field(default_factory=list)
    total_messages_scanned: int = 0
    flagged_count: int = 0
    scan_time_ms: int = 0

class ChatAnalyseRequest(BaseModel):
    chat_id: str
    limit: int = 100           # max messages to fetch

class BatchAnalysisResult(BaseModel):
    total_chats: int = 0
    chats_scanned: int = 0
    high_risk_chats: list[ChatAnalysisResult] = Field(default_factory=list)
    safe_chats: int = 0
    scan_time_ms: int = 0
```

