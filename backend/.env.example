# ── FastAPI / Runtime ───────────────────────────────
FASTAPI_DEBUG=true
FASTAPI_SECRET_KEY=dev-secret-change-me
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── CORS (frontend dev origins) ─────────────────────
# Comma-separated list of allowed origins (no spaces)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend link ───────────────────────────────────
# Internal URL the backend trusts; used by Next.js rewrites
FRONTEND_DEV_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SERVICE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# ── Authkey.io (SMS & Voice Alerts) ────────────────────────
AUTHKEY_API_KEY=your-authkey-api-key
AUTHKEY_SENDER_ID=RAKSHA
AUTHKEY_COUNTRY_CODE=91

# ── SENTINEL (AI Model Config) ────────────────────────────
SENTINEL_WHISPER_MODEL=base
SENTINEL_WHISPER_DEVICE=cpu

# ── Live intelligence partner webhooks ──────────────────────────────────────
# Generate a long random value and set REQUIRE_SIGNATURE=true outside local dev.
INTEGRATION_HMAC_SECRET=replace-with-a-long-random-secret
INTEGRATION_REQUIRE_SIGNATURE=false
INTEGRATION_MAX_EVENT_AGE_SECONDS=300
EVIDENCE_LEDGER_PATH=data_runtime/evidence_ledger.sqlite3
EVIDENCE_PACKAGE_DB_PATH=data_runtime/evidence_packages.sqlite3
EVIDENCE_SIGNING_PRIVATE_KEY_PATH=data_runtime/evidence_signing_private.pem
EVIDENCE_SIGNING_PUBLIC_KEY_PATH=data_runtime/evidence_signing_public.pem

# ── NCRP / agency feed gateway ──────────────────────────────────────────────
AGENCY_FEED_HMAC_SECRET=replace-with-a-distinct-long-random-secret
AGENCY_FEED_REQUIRE_SIGNATURE=false
AGENCY_FEED_MAX_EVENT_AGE_SECONDS=300
AGENCY_FEED_DB_PATH=data_runtime/agency_feeds.sqlite3

# ── NETRA trained-model registry ────────────────────────────────────────────
NETRA_MODEL_DIR=data/netra/models
NETRA_DATASET_DIR=data/netra/datasets
NETRA_MIN_VALIDATION_ACCURACY=0.90
NETRA_MAX_FALSE_POSITIVE_RATE=0.05


# ── NumVerify / Phone Owner Lookup ────────────────────────────────────────────
# Free tier: 1,000 lookups/month — https://numverify.com/
# Provides: carrier name, line type (mobile/landline), telecom circle
NUMVERIFY_API_KEY=your-numverify-api-key

# AbstractAPI Phone Validation (fallback)
# Free tier: 500 lookups/month — https://www.abstractapi.com/api/phone-validation-api
ABSTRACT_PHONE_API_KEY=your-abstractapi-key
